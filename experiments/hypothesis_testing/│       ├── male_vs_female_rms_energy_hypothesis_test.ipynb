# Hypothesis Testing in Speech Emotion Recognition (SER)

## Male vs Female Comparison using RMS Energy

**Dataset**: RAVDESS (audio_speech_actors_01-24)  
**Goal**: Test whether there is a statistically significant difference in audio features between male and female speakers.

from google.colab import files
import zipfile
import os

# Upload your zip file
uploaded = files.upload()

# Unzip
zip_name = "audio_speech_actors_01-24.zip"   # Change this if your zip name is different

with zipfile.ZipFile(zip_name, 'r') as zip_ref:
    zip_ref.extractall('/content/')

print("✅ Dataset unzipped successfully!")
print("Sample files:", os.listdir('/content/audio_speech_actors_01-24')[:5])
import pandas as pd
import numpy as np
import librosa
import matplotlib.pyplot as plt
import seaborn as sns
from scipy import stats

data_path = '/content/audio_speech_actors_01-24'

# Collect wav files
wav_files = [os.path.join(root, file) 
             for root, dirs, files in os.walk(data_path) 
             for file in files if file.endswith('.wav')]

print(f"Total audio files: {len(wav_files)}")

# Parse metadata
data = []
for file_path in wav_files:
    filename = os.path.basename(file_path)
    parts = filename.split('-')
    if len(parts) >= 7:
        emotion_code = int(parts[2])
        intensity = int(parts[3])
        actor = int(parts[6].split('.')[0])
        
        emotion_map = {1:'neutral', 3:'happy', 4:'sad', 5:'angry',
                      6:'fearful', 7:'disgust', 8:'surprised'}
        
        data.append({
            'file': file_path,
            'emotion': emotion_map.get(emotion_code, 'unknown'),
            'intensity': 'high' if intensity == 2 else 'normal',
            'actor': actor,
            'gender': 'female' if actor % 2 == 0 else 'male'
        })

df = pd.DataFrame(data)
print("\nGender Distribution:\n", df['gender'].value_counts())
def extract_rms(file_path):
    y, sr = librosa.load(file_path, duration=3.0)
    rms = librosa.feature.rms(y=y)[0]
    return np.mean(rms)

# Sample for faster runtime (increase to 500-800 later)
sample_df = df.sample(400, random_state=42)
sample_df['rms_energy'] = sample_df['file'].apply(extract_rms)

# Hypothesis Test: Male vs Female
male = sample_df[sample_df['gender'] == 'male']['rms_energy']
female = sample_df[sample_df['gender'] == 'female']['rms_energy']

t_stat, p_value = stats.ttest_ind(male, female, alternative='two-sided')

print("\n=== t-test Results: Male vs Female (RMS Energy) ===")
print(f"t-statistic : {t_stat:.4f}")
print(f"p-value     : {p_value:.6f}")

if p_value < 0.05:
    print("✅ Significant difference found between Male and Female speakers.")
else:
    print("No significant difference.")

# Visualization
plt.figure(figsize=(8,5))
sns.boxplot(x='gender', y='rms_energy', data=sample_df)
plt.title('RMS Energy: Male vs Female in SER Dataset')
plt.show()
